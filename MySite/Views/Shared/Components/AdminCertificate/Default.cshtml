
@{
    Layout = null;
}

<div id="sertifikalar" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>Sertifikalar</h2>
            <p>Sistem üzerindeki güncel veriler ve yönetim paneli.</p>
        </div>
        <div class="date-badge">
            <i class="ri-calendar-line"></i>
            <span>14 Şubat 2026</span>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni Sertifika Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>CERTIFICATEID</th>
                    <th>CERTIFICATENAME</th>
                    <th>COMPANYNAME (KURUM)</th>
                    <th>YEAR</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td><strong>Sertifika Örneği 1</strong></td>
                    <td>Online Eğitim Platformu</td>
                    <td>2024</td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td><strong>Sertifika Örneği 2</strong></td>
                    <td>Teknoloji Kurumu</td>
                    <td>2023</td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>