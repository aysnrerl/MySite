
@{
    Layout = null;
}

<div id="projeler" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>Projeler</h2>
            <p>Sistem üzerindeki güncel veriler ve yönetim paneli.</p>
        </div>
        <div class="date-badge">
            <i class="ri-calendar-line"></i>
            <span>14 Şubat 2026</span>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni Proje Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>PROJECTID</th>
                    <th>PROJECTNAME</th>
                    <th>PROJECTDESCRIPTION</th>
                    <th>USINGTECHNOLOGIES</th>
                    <th>PROJECTURL</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td><strong>Proje A</strong></td>
                    <td>
                        <div style="font-size: 13px; color: var(--text-muted); max-width: 300px;">
                            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
                            incididunt ut labore...
                        </div>
                    </td>
                    <td>
                        <div class="tech-stack">
                            React, Node.js, MongoDB, Express
                        </div>
                    </td>
                    <td>
                        <a href="#" class="link-blue">İncele <i class="ri-external-link-line"></i></a>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td><strong>Proje B</strong></td>
                    <td>
                        <div style="font-size: 13px; color: var(--text-muted); max-width: 300px;">
                            Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip
                            ex ea commodo...
                        </div>
                    </td>
                    <td>
                        <div class="tech-stack">
                            Vue.js, Firebase, Tailwind CSS
                        </div>
                    </td>
                    <td>
                        <a href="#" class="link-blue">İncele <i class="ri-external-link-line"></i></a>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>