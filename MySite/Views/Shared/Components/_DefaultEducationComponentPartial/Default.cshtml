@using MySite.Models
@model TblEducation
<section class="py-24 bg-white dark:bg-surface-dark/30" id="education">
    <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold mb-10 flex items-center justify-center gap-4">
            <span class="material-icons-round text-primary text-3xl">school</span>
            Education
        </h2>
        <div class="max-w-3xl mx-auto space-y-6">
            <div class="bg-background-light dark:bg-background-dark p-6 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-6 hover:-translate-y-1 transition-transform">
                <div class="w-16 h-16 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center shrink-0">
                    <span class="material-icons-round text-3xl">account_balance</span>
                </div>
                <div>
                    <h4 class="text-xl font-bold text-slate-900 dark:text-white">@Model.EducationTitle</h4>
                    <p class="text-slate-600 dark:text-slate-400">@Model.Subtitle</p>
                    <p class="text-sm text-primary mt-1">@Model.EducationYear</p>
                </div>
            </div>
           
        </div>
    </div>
</section>