
@{
    Layout = null;
}

<div id="egitim" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>Eğitim</h2>
            <p>Eğitim geçmişi ve okul bilgileri.</p>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni Eğitim Bilgisi Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>OKUL</th>
                    <th>BÖLÜM / AÇIKLAMA</th>
                    <th>YIL</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>Üniversite Adı</td>
                    <td>
                        <div><strong>Bölüm Adı</strong></div>
                        <div style="font-size: 12px; color: var(--text-muted);">
                            Öğrenci olarak eğitim devam
                            ediyor...
                        </div>
                    </td>
                    <td>20xx - Devam Ediyor</td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>Lise Adı</td>
                    <td>
                        <div><strong>Bölüm / Alan</strong></div>
                        <div style="font-size: 12px; color: var(--text-muted);">Başarı ile mezun olundu...</div>
                    </td>
                    <td>20xx - 20xx</td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>