
@{
    Layout = null;
}

<div id="iletisim" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>İletişim</h2>
            <p>Sistem üzerindeki güncel veriler ve yönetim paneli.</p>
        </div>
        <div class="date-badge">
            <i class="ri-calendar-line"></i>
            <span>14 Şubat 2026</span>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni İletişim Bilgisi Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>CONTACTID</th>
                    <th>DESCRIPTION</th>
                    <th>EMAILADDRESS</th>
                    <th>LINKEDINURL</th>
                    <th>GITHUBURL</th>
                    <th>INSTAGRAMURL</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>
                        <div style="font-size: 13px; color: var(--text-muted); max-width: 250px;">
                            Proje fikirleriniz için iletişime geçebilirsiniz.
                        </div>
                    </td>
                    <td>email@example.com</td>
                    <td><a href="#" class="link-url">https://linkedin.com/in/username</a></td>
                    <td><a href="#" class="link-url">https://github.com/username</a></td>
                    <td><a href="#" class="link-url">https://instagram.com/username</a></td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
