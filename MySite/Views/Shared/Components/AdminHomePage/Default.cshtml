
@{
    Layout = null;
}

<div id="ana-bilgiler" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>Ana Bilgiler</h2>
            <p>Web sitesi ana başlık ve açıklama yönetimi.</p>
        </div>
        <div class="date-badge">
            <i class="ri-calendar-line"></i>
            <span>17 Şubat 2026</span>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni Bilgi Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>GÖRSEL</th>
                    <th>BAŞLIK</th>
                    <th>ALT BAŞLIK</th>
                    <th>AÇIKLAMA</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><img src="https://via.placeholder.com/40" alt="Profil" class="img-thumb"></td>
                    <td>Ad Soyad</td>
                    <td>Yazılım Geliştirici</td>
                    <td>
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Portfolio siteme hoşgeldiniz...
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
