
@{
    Layout = null;
}


<div id="hakkimda" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>Hakkında</h2>
            <p>Kişisel bilgiler ve biyografi yönetimi.</p>
        </div>
        <div class="date-badge">
            <i class="ri-calendar-line"></i>
            <span>17 Şubat 2026</span>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni Hakkında Yazısı Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>BAŞLIK</th>
                    <th>İÇERİK</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="3">
                        <div class="empty-state">Henüz veri eklenmemiş.</div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
