
@{
    Layout = null;
}

<div id="yetenekler" class="section-view">
    <div class="top-bar">
        <div class="page-title">
            <h2>Yetenekler</h2>
            <p>Sistem üzerindeki güncel veriler ve yönetim paneli.</p>
        </div>
        <div class="date-badge">
            <i class="ri-calendar-line"></i>
            <span>14 Şubat 2026</span>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-primary">
            <i class="ri-add-line"></i> Yeni Yetenek Ekle
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>SKILLID</th>
                    <th>SKILLNAME</th>
                    <th>PERCENT (YÜZDE)</th>
                    <th>İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td><strong>Yetenek A</strong></td>
                    <td>
                        <div class="progress-wrapper">
                            <div class="progress-container">
                                <div class="progress-bar" style="width: 85%;"></div>
                            </div>
                            <span class="progress-text">%85</span>
                        </div>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td><strong>Yetenek B</strong></td>
                    <td>
                        <div class="progress-wrapper">
                            <div class="progress-container">
                                <div class="progress-bar" style="width: 60%;"></div>
                            </div>
                            <span class="progress-text">%60</span>
                        </div>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>3</td>
                    <td><strong>Yetenek C</strong></td>
                    <td>
                        <div class="progress-wrapper">
                            <div class="progress-container">
                                <div class="progress-bar" style="width: 90%;"></div>
                            </div>
                            <span class="progress-text">%90</span>
                        </div>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>4</td>
                    <td><strong>Yetenek D</strong></td>
                    <td>
                        <div class="progress-wrapper">
                            <div class="progress-container">
                                <div class="progress-bar" style="width: 45%;"></div>
                            </div>
                            <span class="progress-text">%45</span>
                        </div>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-green"><i class="ri-edit-line"></i> Güncelle</button>
                            <button class="btn btn-sm btn-red"><i class="ri-delete-bin-line"></i> Sil</button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
